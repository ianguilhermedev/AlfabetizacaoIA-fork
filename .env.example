# ============================================================
# WHATSAPP — Meta Cloud API
# ============================================================
WHATSAPP_TOKEN=
WHATSAPP_PHONE_ID=
WHATSAPP_VERIFY_TOKEN=

# ============================================================
# PROVEDOR DE IA
# Opções: ollama (processamento local) | gemini (nuvem)
# ============================================================
AI_PROVIDER=ollama

# ============================================================
# OLLAMA — Processamento Local
# ============================================================
OLLAMA_API_URL=http://localhost:11434/api/generate
OLLAMA_MODEL=llama3.2

# SLA e parâmetros de geração (todos configuráveis)
OLLAMA_TIMEOUT=25              # Segundos máximos de espera — SLA estrito
OLLAMA_NUM_PREDICT=250         # Máximo de tokens gerados (~150-200 palavras)
OLLAMA_TEMPERATURE=0.4         # 0.3-0.5 = foco pedagógico, menor alucinação
OLLAMA_TOP_P=0.9               # Amostragem de núcleo estável
OLLAMA_REPETITION_PENALTY=1.2  # Evita loops de texto (comum em modelos 3B)
OLLAMA_NUM_CTX=1024            # Janela de contexto conservadora para <8GB RAM

# ============================================================
# GEMINI — Processamento na Nuvem (fallback/escalabilidade)
# Ative com: AI_PROVIDER=gemini
# ============================================================
GEMINI_API_KEY=sua_chave_aqui
GEMINI_MODEL=gemini-1.5-flash

# ============================================================
# CHROMADB — RAG (Retrieval-Augmented Generation)
# ATENÇÃO: ao trocar CHROMA_EMBEDDING_MODEL, apague data/chroma_db/
# e re-execute o script de ingestão para re-indexar os documentos.
# ============================================================
CHROMA_EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
CHROMA_N_RESULTS=4
CHROMA_SCORE_THRESHOLD=1.0

# ============================================================
# WHISPER — Transcrição de Áudio
# Modelos: tiny | base | small | medium | large-v3
# Devices: cpu | cuda (requer GPU compatível com CUDA)
# Compute: int8 (cpu) | float16 (cuda)
# ============================================================
WHISPER_MODEL=base
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# ============================================================
# BANCO DE DADOS E CAMINHOS
# ============================================================
DATABASE_URL=sqlite:///./data/alfabot.db
CHROMA_PATH=./data/chroma_db

# ============================================================
# AMBIENTE E SERVIDOR
# ============================================================
FLASK_ENV=development
PORT=5000
